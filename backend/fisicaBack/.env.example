# ============================================================================
# Plantilla de variables de entorno — Seguridad Física (backend Django)
# ----------------------------------------------------------------------------
# Copia este archivo a `.env` y completa los valores reales.
#   cp .env.example .env
# NUNCA subas el archivo `.env` real al repositorio (debe estar en .gitignore).
# ============================================================================

# --- Núcleo / seguridad -----------------------------------------------------
# Clave secreta de Django. Genera una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria

# DEBUG: en producción SIEMPRE False. Valores válidos: True/False/1/0/yes/no
DEBUG=False

# Hosts permitidos (separados por coma). En producción, el dominio/IP del servidor.
ALLOWED_HOSTS=localhost,127.0.0.1

# Orígenes de confianza para CSRF (separados por coma, con esquema http/https).
CSRF_TRUSTED_ORIGINS=http://localhost:4200,https://fisica.oceansecurity.net

# Orígenes permitidos para CORS (separados por coma).
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://fisica.oceansecurity.net

# --- Base de datos (PostgreSQL) ---------------------------------------------
DB_NAME=sf_bd
DB_USER=postgres
DB_PASSWORD=cambia-esta-contrasena
DB_HOST=localhost
DB_PORT=5432

# Contraseña del contenedor de Postgres (debe coincidir con DB_PASSWORD en Docker).
POSTGRES_PASSWORD=cambia-esta-contrasena

# --- Email (envío de reseteo de contraseña, notificaciones) -----------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=tu-correo@dominio.com
EMAIL_HOST_PASSWORD=contrasena-o-app-password
DEFAULT_FROM_EMAIL=tu-correo@dominio.com

# --- Políticas de contraseña / reseteo --------------------------------------
# Longitud mínima de contraseña.
PASSWORD_MIN_LENGTH=8
# URL base a la que apunta el enlace de reseteo (frontend).
PASSWORD_RESET_BASE_URL=http://localhost:4200
# Anti-abuso del reseteo de contraseña.
RESET_PASSWORD_COOLDOWN_SECONDS=60
RESET_PASSWORD_MAX_PER_HOUR=5
